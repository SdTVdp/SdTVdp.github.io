{
  "name": "minimal-cascade-hexo",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal searchable Hexo site for GitHub Pages",
  "scripts": {
    "clean": "node tools/clean.mjs && hexo clean",
    "typecheck:hexo": "tsc --noEmit -p tsconfig.hexo.json",
    "typecheck:client": "tsc --noEmit -p tsconfig.client.json",
    "typecheck": "npm run typecheck:hexo && npm run typecheck:client",
    "compile:hexo": "tsc -p tsconfig.hexo.json",
    "compile:client": "tsc -p tsconfig.client.json",
    "compile": "npm run compile:hexo && npm run compile:client",
    "build": "npm run typecheck && npm run compile && hexo generate",
    "server": "npm run compile && hexo server"
  },
  "hexo": {
    "version": "8.1.1"
  },
  "dependencies": {
    "hexo": "^8.1.1",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-searchdb": "^1.5.0",
    "hexo-generator-tag": "^2.0.0",
    "hexo-renderer-marked": "^7.0.1",
    "hexo-renderer-pug": "^3.0.0",
    "hexo-renderer-stylus": "^3.0.1",
    "hexo-server": "^3.0.0",
    "hexo-theme-butterfly": "^5.5.4"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "sharp": "^0.34.4",
    "typescript": "^5.9.3"
  }
}
