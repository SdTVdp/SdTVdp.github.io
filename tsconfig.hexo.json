{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist/hexo",
    "rootDir": "src/ts/hexo",
    "types": ["node"]
  },
  "include": ["src/ts/hexo/**/*.ts", "src/ts/hexo/**/*.d.ts"]
}
